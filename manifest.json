{
  "manifest_version": 3,
  "name": "GF Code: Site to Markdown",
  "version": "1.0.0",
  "description": "Browser extension to extract website content into clean markdown optimized for LLMs",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "downloads"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "GF Code: Site to Markdown"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "icons": {
    "16": "public/icons/icon16.png",
    "32": "public/icons/icon32.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  }
}
